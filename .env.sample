# Required for publishing to Tableau Cloud
TOKEN_NAME=your_token_name
TOKEN_VALUE=your_token_value
SITE_ID=your_site_id
SERVER_URL=https://prod-uk-a.online.tableau.com
PROJECT_NAME=your_project_name
DATASOURCE_NAME=your_datasource_name

# Optional overrides (defaults to the local files)
# JSON_FILE_PATH=2026_govwifi_data.json
# HYPER_FILE_PATH=2026_govwifi_data.hyper
# TABLE_NAME=Extract

# Required for metrics data recovery
METRICS_API_URL=https://api.govwifi.service.gov.uk
METRICS_API_KEY=your_metrics_api_key

# Optional recovery overrides
# RECOVER_YEAR=2026
# RECOVER_MONTH=5
